# === Vohaus Ads Hub — variáveis de ambiente ===
# Copie para .env e preencha com valores reais. NÃO commitar o .env.

# Proteção da API (obrigatória). Sem ela o servidor recusa iniciar.
# Use um segredo forte e aleatório, ex: openssl rand -hex 32
API_SECRET=

# Servidor
ADS_PORT=3001
APP_URL=http://localhost:3001
# Origens permitidas para CORS, separadas por vírgula. Vazio/ausente = '*'
ALLOWED_ORIGINS=

# Banco de dados (PostgreSQL)
DATABASE_URL=postgres://usuario:senha@host:5432/banco

# Google Ads / OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=

# Anthropic (recursos de IA)
ANTHROPIC_API_KEY=
